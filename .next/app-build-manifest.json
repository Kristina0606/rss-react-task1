{
  "pages": {
    "/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/not-found.js",
      "static/css/app/not-found.css"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/_not-found/page.js",
      "static/css/app/_not-found/page.css"
    ],
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/layout.js"
    ],
    "/[[...slug]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/[[...slug]]/page.css",
      "static/chunks/app/[[...slug]]/page.js"
    ]
  }
}